centrality <- function(x, ...){
UseMethod("centrality")
}
centrality.data.frame <- function(x, ...) {
result <- lapply(x, function(col) {
list(
Mean = mean(col, ...),
Median = median(col, ...),
Mode = as.numeric(names(sort(table(col), decreasing = TRUE)[1]))
)
})
return(result)
}
centrality <- function(x, ...){
UseMethod("centrality")
}
#S3 method for data.frame
centrality.data.frame <- function(x, ...) {
result <- lapply(x, function(col) {
list(
Mean = mean(col, ...),
Median = median(col, ...),
Mode = as.numeric(names(sort(table(col), decreasing = TRUE)[1]))
)
})
return(result)
}
